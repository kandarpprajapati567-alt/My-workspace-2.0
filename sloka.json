[
    { "id": "1_1", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "रागादिरोगान् सततानुषक्तानशेषकायप्रसृतानशेषान् । औत्सुक्यमोहारतिदान् जघान योऽपूर्ववैद्याय नमोऽस्तु तस्मै ॥" },
    { "id": "1_2", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "आयुःकामयमानेन धर्मार्थसुखसाधनम् । आयुर्वेदोपदेशेषु विधेयः परमादरः ॥" },
    { "id": "1_3", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "ब्रह्मा स्मृत्वाऽऽयुषो वेदं प्रजापतिमजिग्रहत् । सोऽश्विनौ तौ सहस्राक्षं सोऽत्रिपुत्रादिकान्मुनीन् ॥" },
    { "id": "1_4", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "तेऽग्निवेशादिकांस्ते तु पृथक्तन्त्राणि तेनिरे । तेभ्योऽतिविप्रकीर्णेभ्यः प्रायः सारतरोच्चयः ॥" },
    { "id": "1_5", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "क्रियतेऽष्टाङ्गहृदयमनाकुलमविस्तरम् ।" },
    { "id": "1_5a", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "कायबालग्रहोर्ध्वाङ्गशल्यदंष्ट्राजरावृषान् ।" },
    { "id": "1_6", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "अष्टावङ्गानि तस्याहुश्चिकित्सा येषु संश्रिता ॥" },
    { "id": "1_7", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "वायुः पित्तं कफश्चेति त्रयो दोषाः समासतः । विकृताऽविकृता देहं घ्नन्ति ते वर्तयन्ति च ॥" },
    { "id": "1_8", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "ते व्यापिनोऽपि हृन्नाभ्योरधोमध्योर्ध्वसंश्रयाः ।" },
    { "id": "1_9", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "वयोऽहोरात्रिभुक्तानां तेऽन्तमध्यादिगाः क्रमात् ।" },
    { "id": "1_10", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "तैर्भवेद्विषमस्तीक्ष्णो मन्दश्चाग्निः समैः समः ।" },
    { "id": "1_11", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "कोष्ठः क्रूरो मृदुर्मध्यो मध्यः स्यात्तैः समैरपि ॥" },
    { "id": "1_12", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "शुक्रार्तवस्थैर्जन्मादौ विषेणेव विषकृमेः । तैश्च तिस्रः प्रकृतयो हीनमध्योत्तमाः पृथक् ॥" },
    { "id": "1_13", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "समधातुः समस्तासु श्रेष्ठा निन्द्या द्विदोषजाः ।" },
    { "id": "1_14", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "तत्र रूक्षो लघुः शीतः खरः सूक्ष्मश्चलोऽनिलः ।" },
    { "id": "1_15", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "पित्तं सस्नेहतीक्ष्णोष्णं लघु विस्रं सरं द्रवम् ।" },
    { "id": "1_16", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "स्निग्धः शीतो गुरुर्मन्दः श्लक्ष्णो मृत्स्नः स्थिरः कफः ॥" },
    { "id": "1_17", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "संसर्गः सन्निपातश्च तद्द्वित्रिक्षयकोपतः ।" },
    { "id": "1_18", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "रसासृङ्मांसमेदोऽस्थिमज्जशुक्राणि धातवः । सप्त दूष्याः मला मूत्रशकृत्स्वेदादयोऽपि च ॥" },
    { "id": "1_19", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "वृद्धिः समानैः सर्वेषां विपरीतैर्विपर्ययः ।" },
    { "id": "1_20", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "रसाः स्वाद्वम्ललवणतिक्तोषणकषायकाः । षड् द्रव्यमाश्रितास्ते च यथापूर्वं बलावहाः ॥" },
    { "id": "1_21", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "तत्राद्या मारुतं घ्नन्ति त्रयस्तिक्तादयः कफम् ।" },
    { "id": "1_22", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "कषायतिक्तमधुराः पित्तमन्ये तु कुर्वते ॥" },
    { "id": "1_23", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "शमनं कोपनं स्वस्थहितं द्रव्यमिति त्रिधा ।" },
    { "id": "1_24", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "उष्णशीतगुणोत्कर्षात्तत्र वीर्यं द्विधा स्मृतम् ॥" },
    { "id": "1_25", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "त्रिधा विपाको द्रव्यस्य स्वाद्वम्लकटुकात्मकः ।" },
    { "id": "1_26", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "गुरुमन्दहिमस्निग्धश्लक्ष्णसान्द्रमृदुस्थिराः । गुणाः ससूक्ष्मविशदा विंशतिः सविपर्ययाः ॥" },
    { "id": "1_27", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "रोगस्तु दोषवैषम्यं दोषसाम्यमरोगता ।" },
    { "id": "1_28", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "निजागन्तुविभागेन तत्र रोगो द्विधा स्मृतः ॥" },
    { "id": "1_29", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "तेषां कायमनोभेदादधिष्ठानमपि द्विधा ।" },
    { "id": "1_30", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "रजस्तमश्च मनसो द्वौ च दोषावुदाहृतौ ।" },
    { "id": "1_31", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "दर्शनस्पर्शनप्रश्नैः परीक्षेत रोगिणम् ।" },
    { "id": "1_32", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "रोगं निदानप्राग्रूपलक्षणोपशयाप्तिभिः ॥" },
    { "id": "1_33", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "भूमिदेहप्रभेदेन देशमाहुर्द्विधा पुनः । जाङ्गलं वातभूयिष्ठमनूपं तु कफोल्बणम् ॥" },
    { "id": "1_34", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "साधारणं सममलं त्रिधा भूदेशमादिशेत् । क्षणादिर्व्याध्यवस्था च कालो द्विधा प्रकीर्तितः ॥" },
    { "id": "1_35", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "शोधनं शमनं चेति समासादौषधं द्विधा ।" },
    { "id": "1_36", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "बस्तिर्विरेको वमनं तथा तैलं घृतं मधु ॥" },
    { "id": "1_37", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "वातपित्तकफानां च क्रमेण परमौषधम् ।" },
    { "id": "1_38", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "धीधैर्यात्मादिविज्ञानं मनोदोषौषधं परम् ॥" },
    { "id": "1_39", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "भिषग्द्रव्यान्युपस्थाता रोगी पादचतुष्टयम् । चिकित्सितस्य निर्दिष्टं प्रत्येकं तच्चतुर्गुणम् ॥" },
    { "id": "1_40", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "दक्षस्तीर्थात्तशास्त्रार्थो दृष्टकर्मा शुचिर्भिषक् ।" },
    { "id": "1_41", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "बहुकल्पं बहुगुणं सम्पन्नं योग्यमौषधम् ॥" },
    { "id": "1_42", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "अनुरक्तः शुचिर्दक्षो बुद्धिमान् परिचारकः ।" },
    { "id": "1_43", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "आढ्यो रोगी भिषग्वश्यो ज्ञापकः सत्त्ववानपि ॥" },
    { "id": "1_44", "samhita": "Ashtang Hridayam", "chapter": "सूत्रस्थान (आयुषकामीय अध्याय)", "text": "साध्योऽसाध्य इति व्याधिर्द्विधा ते तु पुनर्द्विधा । सुसाध्यः कृच्छ्रसाध्यश्च याप्यो यश्चानुपक्रमः ॥" },
    { "id": "1_45", "samhita": "Ashtang Hridayam", "chapter": "दिनचर्या अध्याय", "text": "ब्राह्मे मुहूर्ते उत्तिष्ठेत् स्वस्थो रक्षार्थमायुषः । शरीरचिन्तां निर्वर्त्य कृतशौचविधिस्ततः ॥" },
    { "id": "c1_1", "samhita": "Charak Samhita", "chapter": "सूत्रस्थान (दीर्घञ्जीवितीयमध्याय)", "text": "दीर्घञ्जीवितीयमध्यायं व्याख्यास्यामः । इति ह स्माह भगवानात्रेयः ॥" },
    { "id": "c1_2", "samhita": "Charak Samhita", "chapter": "सूत्रस्थान (दीर्घञ्जीवितीयमध्याय)", "text": "धर्मार्थकाममोक्षाणामारोग्यं मूलमुत्तमम् । रोगास्तस्यापहर्तारः श्रेयसो जीवितस्य च ॥" },
    { "id": "s1_1", "samhita": "Sushruta Samhita", "chapter": "सूत्रस्थान (वेदोत्पत्ति)", "text": "अथातो वेदोत्पत्तिमध्यायं व्याख्यास्यामः ।" },
    { "id": "s1_2", "samhita": "Sushruta Samhita", "chapter": "सूत्रस्थान (वेदोत्पत्ति)", "text": "आयुर्वेदं अष्टाङ्गं उपदिश्यते ।" },
    { "id": "p1_1", "samhita": "Padarth Vigyan", "chapter": "आयुर्वेद निरुपण", "text": "हिताहितं सुखं दुःखमायुस्तस्य हिताहितम् । मानं च तच्च यत्रोक्तमायुर्वेदः स उच्यते ॥" }
]
